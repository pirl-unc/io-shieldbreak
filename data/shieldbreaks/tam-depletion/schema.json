{
  "shieldbreak": "tam-depletion",
  "display_title": "Tumor-associated Macrophage Depletion, Inhibition, or Repolarization",
  "research_question": "Which clinical interventions deplete, inhibit, or repolarize tumor-associated macrophages (TAMs) in humans, and how durable / context-dependent is that effect?",
  "schema_version": 1,
  "row_grain": "study x tissue x timepoint_cluster x dose_cohort",
  "columns": [
    {"name": "row_id", "type": "string", "required": true},
    {"name": "supersedes", "type": "string|null"},
    {"name": "intervention", "type": "string", "required": true},
    {"name": "intervention_class", "type": "enum", "required": true, "values": ["csf1r-inhibitor", "pi3kg-inhibitor", "ccr2-ccr5-inhibitor", "bisphosphonate", "trabectedin-lurbinectedin", "cd47-sirpa-blockade", "cd24-blockade", "cd40-agonist", "tlr-agonist", "sting-agonist", "clever1-marco-blockade", "lilrb2-trem2-blockade", "other-repolarizing", "combo"]},
    {"name": "combo_partners", "type": "string|null"},
    {"name": "dose", "type": "string|null"},
    {"name": "dose_cohort_label", "type": "string|null"},
    {"name": "indication", "type": "string", "required": true},
    {"name": "patient_population", "type": "string"},
    {"name": "n_treated_with_tam_measurement", "type": "integer", "required": true, "min": 3},
    {"name": "design_type", "type": "enum", "values": ["paired-pre-post", "treated-vs-untreated", "single-arm-descriptive", "randomized-controlled", "window-of-opportunity", "case-series"]},
    {"name": "phase", "type": "enum|null", "values": ["1", "1/2", "2", "2/3", "3", "4", "translational", "N/A"]},
    {"name": "nct_id", "type": "string|null"},
    {"name": "tissue", "type": "enum", "required": true, "values": ["tumor", "PBMC", "TDLN", "bone-marrow", "ascites", "pleural-effusion", "skin", "other"]},
    {"name": "tissue_detail", "type": "string|null"},
    {"name": "tam_definition", "type": "string"},
    {"name": "gating_quality", "type": "enum", "values": ["CD68-CD163-based", "CD68-CD206-based", "CD14-CD16-based", "CD68-MHCII-based", "scRNA-macrophage-cluster", "mIF-multiplex", "CyTOF", "single-marker-only", "mixed-or-unclear"]},
    {"name": "readout_type", "type": "enum", "values": ["absolute-count", "frequency-of-CD45", "frequency-of-myeloid", "frequency-of-live", "ratio-M1-to-M2", "polarization-marker-shift", "phagocytosis-function", "scRNA-cluster-shift", "other"]},
    {"name": "timepoint_cluster", "type": "enum", "values": ["baseline", "early-on-treatment", "mid", "late", "post-progression", "off-treatment-recovery"]},
    {"name": "timepoint_detail", "type": "string|null"},
    {"name": "baseline_value", "type": "string|null"},
    {"name": "baseline_stat_type", "type": "enum|null", "values": ["mean-sd", "median-iqr", "median-range", "range", "point-estimate", "geometric-mean", "not-reported"]},
    {"name": "post_value", "type": "string|null"},
    {"name": "post_stat_type", "type": "enum|null", "values": ["mean-sd", "median-iqr", "median-range", "range", "point-estimate", "geometric-mean", "not-reported"]},
    {"name": "change_direction", "type": "enum", "values": ["decrease", "increase", "no-change", "mixed", "not-reported"]},
    {"name": "change_magnitude", "type": "string|null"},
    {"name": "change_significance", "type": "string|null"},
    {"name": "change_mechanism", "type": "enum", "values": ["absolute-reduction", "ratio-shift", "repolarization", "expansion-with-repolarization", "functional-impairment-only", "null-result"]},
    {"name": "pct_change", "type": "float|null", "description": "Signed relative percent change in TAM measure (negative = reduction). For repolarization rows with a single quantified marker, use that marker's signed delta. Null when qualitative-only or when authors explicitly state no significant change."},
    {"name": "pct_change_stat", "type": "enum|null", "values": ["point", "mean", "median", "range-midpoint", "fold-derived"]},
    {"name": "pct_change_source", "type": "string|null"},
    {"name": "durability_days", "type": "integer|null"},
    {"name": "durability_described", "type": "string|null"},
    {"name": "depletion_success", "type": "enum", "values": ["succeeded", "partial", "failed", "not-assessed"], "description": "Semantics vary by change_mechanism: absolute count reduction for absolute-reduction; favorable ratio shift for ratio-shift; multi-marker M1-direction shift for repolarization; assay-level functional change for functional-impairment-only. Single-marker IHC alone is not sufficient for `succeeded` on a repolarization row."},
    {"name": "clinical_correlate", "type": "string|null"},
    {"name": "intent_to_deplete", "type": "enum", "values": ["mechanism-targeted", "pre-specified-endpoint", "exploratory-but-prespecified", "incidental-but-measured"]},
    {"name": "notes", "type": "string|null"},
    {"name": "pmid", "type": "string|null"},
    {"name": "pmcid", "type": "string|null"},
    {"name": "doi", "type": "string|null"},
    {"name": "first_author", "type": "string"},
    {"name": "last_author", "type": "string|null"},
    {"name": "year", "type": "integer"},
    {"name": "journal", "type": "string"},
    {"name": "title", "type": "string"},
    {"name": "source_type", "type": "enum", "values": ["pmc_full_text", "europepmc_full_text", "pubmed_abstract", "ctgov_registry", "other"]},
    {"name": "source_url", "type": "string"},
    {"name": "fetch_timestamp_utc", "type": "string"}
  ],
  "side_list": {
    "file": "reviews.jsonl",
    "columns": ["pmid", "pmcid", "doi", "first_author", "year", "journal", "title", "review_type", "scope_summary", "notes", "fetch_timestamp_utc"]
  },
  "deviations_from_treg_depletion": [
    "D1: Blood monocytes only in-scope when paper explicitly pre-specifies them as a TAM surrogate.",
    "D2: Explicit class-level exclusion of checkpoint-inhibitor monotherapy (OK as combo partner).",
    "D3: Healthy-volunteer PD excluded entirely.",
    "D4: IPI-549 / eganelisib split into its own pi3kg-inhibitor class.",
    "D5: Collapse the three mechanism families into orthogonal intervention_class (intent) and change_mechanism (observed).",
    "D6: scRNA-cluster-shift is a first-class readout_type value.",
    "D7: mIF-multiplex and CyTOF are first-class gating_quality values.",
    "D8: durability_days carried over from treg-depletion.",
    "D9: Per-run cap 30, not 50."
  ]
}
