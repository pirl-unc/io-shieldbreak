{
  "shieldbreak": "treg-depletion",
  "schema_version": 1,
  "row_grain": "study x tissue x timepoint_cluster x dose_cohort",
  "columns": [
    {"name": "row_id", "type": "string", "required": true},
    {"name": "supersedes", "type": "string|null"},
    {"name": "intervention", "type": "string", "required": true},
    {"name": "intervention_class", "type": "enum", "required": true, "values": ["anti-CCR4", "anti-CD25", "Fc-enhanced-anti-CTLA-4", "anti-CTLA-4", "low-dose-cyclophosphamide", "denileukin-diftitox", "IL-2-variant", "anti-CD39", "anti-CD73", "A2AR-antagonist", "anti-CCR8", "anti-GITR", "anti-OX40", "EZH2i", "PI3Kdelta-i", "chemo-other", "JAKi", "HDACi", "HMA", "radiation", "combo", "other"]},
    {"name": "combo_partners", "type": "string|null"},
    {"name": "dose", "type": "string|null"},
    {"name": "dose_cohort_label", "type": "string|null"},
    {"name": "indication", "type": "string", "required": true},
    {"name": "patient_population", "type": "string"},
    {"name": "n_treated_with_treg_measurement", "type": "integer", "required": true, "min": 3},
    {"name": "design_type", "type": "enum", "values": ["paired-pre-post", "treated-vs-untreated", "single-arm-descriptive", "randomized-controlled", "window-of-opportunity", "healthy-volunteer-PD", "case-series"]},
    {"name": "phase", "type": "enum|null", "values": ["1", "1/2", "2", "2/3", "3", "4", "translational", "N/A"]},
    {"name": "nct_id", "type": "string|null"},
    {"name": "tissue", "type": "enum", "required": true, "values": ["PBMC", "tumor", "TDLN", "bone-marrow", "ascites", "pleural-effusion", "CSF", "skin", "other"]},
    {"name": "tissue_detail", "type": "string|null"},
    {"name": "treg_definition", "type": "string"},
    {"name": "gating_quality", "type": "enum", "values": ["FOXP3-confirmed", "surface-only", "functional-assay", "mixed", "unclear"]},
    {"name": "readout_type", "type": "enum", "values": ["absolute-count", "frequency-of-CD4", "frequency-of-lymphocytes", "frequency-of-CD3", "ratio-to-Teff", "ratio-to-CD8", "suppressive-function", "other"]},
    {"name": "timepoint_cluster", "type": "enum", "values": ["baseline", "early-on-treatment", "mid", "late", "post-progression", "off-treatment-recovery"]},
    {"name": "timepoint_detail", "type": "string|null"},
    {"name": "baseline_value", "type": "string|null"},
    {"name": "baseline_stat_type", "type": "enum|null", "values": ["mean-sd", "median-iqr", "median-range", "range", "point-estimate", "geometric-mean", "not-reported"]},
    {"name": "post_value", "type": "string|null"},
    {"name": "post_stat_type", "type": "enum|null", "values": ["mean-sd", "median-iqr", "median-range", "range", "point-estimate", "geometric-mean", "not-reported"]},
    {"name": "change_direction", "type": "enum", "values": ["decrease", "increase", "no-change", "mixed", "not-reported"]},
    {"name": "change_magnitude", "type": "string|null"},
    {"name": "change_significance", "type": "string|null"},
    {"name": "change_mechanism", "type": "enum", "values": ["absolute-reduction", "ratio-shift", "expansion-with-ratio-shift", "functional-impairment-only", "null-result"]},
    {"name": "pct_change", "type": "float|null", "description": "Signed relative percent change in Treg measure (negative = reduction). Populated where change_magnitude contains a clean single-number headline or an unambiguous fold-change. Null when the study is qualitative-only, proportional-only (e.g. 4/4 reduced), or authors explicitly state no significant change."},
    {"name": "pct_change_stat", "type": "enum|null", "values": ["point", "mean", "median", "range-midpoint", "fold-derived"], "description": "How pct_change was computed from the source text."},
    {"name": "pct_change_source", "type": "string|null", "description": "Short string citing the text fragment that sourced pct_change, for audit."},
    {"name": "durability_days", "type": "integer|null"},
    {"name": "durability_described", "type": "string|null"},
    {"name": "depletion_success", "type": "enum", "values": ["succeeded", "partial", "failed", "not-assessed"]},
    {"name": "clinical_correlate", "type": "string|null"},
    {"name": "intent_to_deplete", "type": "enum", "values": ["mechanism-targeted", "pre-specified-endpoint", "exploratory-but-prespecified", "incidental-but-measured"]},
    {"name": "notes", "type": "string|null"},
    {"name": "pmid", "type": "string|null"},
    {"name": "pmcid", "type": "string|null"},
    {"name": "doi", "type": "string|null"},
    {"name": "first_author", "type": "string"},
    {"name": "year", "type": "integer"},
    {"name": "journal", "type": "string"},
    {"name": "title", "type": "string"},
    {"name": "source_type", "type": "enum", "values": ["pmc_full_text", "europepmc_full_text", "pubmed_abstract", "ctgov_registry", "other"]},
    {"name": "source_url", "type": "string"},
    {"name": "fetch_timestamp_utc", "type": "string"}
  ],
  "side_list": {
    "file": "reviews.jsonl",
    "columns": ["pmid", "pmcid", "doi", "first_author", "year", "journal", "title", "review_type", "scope_summary", "notes", "fetch_timestamp_utc"]
  }
}
